[master]
master1 ansible_host=127.0.0.1 ansible_port=2222 ansible_user=vagrant ansible_ssh_private_key_file=./.vagrant/machines/master/vmware_fusion/private_key

[workers]
worker1 ansible_host=127.0.0.1 ansible_port=2200 ansible_user=vagrant ansible_ssh_private_key_file=./.vagrant/machines/worker1/vmware_fusion/private_key
worker2 ansible_host=127.0.0.1 ansible_port=2201 ansible_user=vagrant ansible_ssh_private_key_file=./.vagrant/machines/worker2/vmware_fusion/private_key
worker3 ansible_host=127.0.0.1 ansible_port=2202 ansible_user=vagrant ansible_ssh_private_key_file=./.vagrant/machines/worker3/vmware_fusion/private_key

[nfs]
nfs1 ansible_host=127.0.0.1 ansible_port=2203 ansible_user=vagrant ansible_ssh_private_key_file=./.vagrant/machines/nfs1/vmware_fusion/private_key

[all:vars]
ansible_ssh_common_args='-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'
